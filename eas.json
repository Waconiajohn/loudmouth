{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "LOUDMOUTH_MOCK_STEMS": "true",
        "LOUDMOUTH_BYPASS_PAYWALL": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "LOUDMOUTH_MOCK_STEMS": "false",
        "LOUDMOUTH_BYPASS_PAYWALL": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "LOUDMOUTH_MOCK_STEMS": "false",
        "LOUDMOUTH_BYPASS_PAYWALL": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
