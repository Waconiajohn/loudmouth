# =============================================================================
# LOUDMOUTH — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase (Client-side — safe to expose) --------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- AudioShake (Server-side ONLY — Edge Function secret) --------------------
# Do NOT prefix with EXPO_PUBLIC_ — this must stay server-side
AUDIOSHAKE_API_KEY=ask_live_...

# --- RevenueCat (Client SDK key — safe to expose) ----------------------------
REVENUECAT_API_KEY=appl_...

# --- RevenueCat (Server-side ONLY — Edge Function secret) --------------------
# Used to verify webhook signatures
REVENUECAT_WEBHOOK_SECRET=whsec_...

# --- Development Overrides ---------------------------------------------------
# Set to 'true' to bypass AudioShake and use mock stems (faster local dev)
# LOUDMOUTH_MOCK_STEMS=false

# Set to 'true' to skip RevenueCat and treat all users as premium
# LOUDMOUTH_BYPASS_PAYWALL=false
